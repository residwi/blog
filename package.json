{
  "name": "personal-blog",
  "version": "1.0.0",
  "keywords": [
    "jekyll",
    "tailwindcss",
    "blog"
  ],
  "author": "Resi Dwi",
  "license": "MIT",
  "scripts": {
    "build:css": "tailwindcss -i ./assets/css/application.css -o ./assets/css/main.css",
    "watch:css": "npm run build:css -- --watch",
    "dev": "npm run build:css && bundle exec jekyll serve --livereload"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.4",
    "tailwindcss": "^3.0.7"
  }
}
