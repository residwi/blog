---
layout: null
---
{% assign search_items = site.posts | concat: site.til %}
[
  {% for item in search_items %}
    {
      "title": {{ item.title | jsonify }},
      "url": {{ item.url | relative_url | jsonify }},
      "content": {{ item.content | strip_html | jsonify }},
      "date": {{ item.date | date: "%Y-%m-%d" | jsonify }},
      "tags": {{ item.tags | jsonify }},
      "type": {{ item.collection | replace: "posts", "post" | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
